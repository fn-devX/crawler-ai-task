# Copy to .env and fill in. Only ANTHROPIC_API_KEY is required for live extraction.
ANTHROPIC_API_KEY=sk-ant-.....
# Model used for relationship extraction.
NEWSKG_MODEL=claude-sonnet-4-6
# SQLite database path.
NEWSKG_DB=newskg.db
# Set to "heuristic" to run without any LLM (author edges only). Default "llm".
NEWSKG_EXTRACTOR=llm
# Polite crawl delay between requests, seconds.
NEWSKG_CRAWL_DELAY=1.0
